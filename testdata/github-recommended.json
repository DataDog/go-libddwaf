{
  "version": "2.1",
  "metadata": {
    "rules_version": "1.13.1"
  },
  "rules": [
    {
      "id": "ua0-600-12x",
      "name": "Arachni",
      "tags": {
        "type": "security_scanner",
        "category": "attack_attempt"
      },
      "conditions": [
        {
          "operator": "match_regex",
          "parameters": {
            "inputs": [
              {
                "address": "server.request.headers.no_cookies",
                "key_path": ["user-agent"]
              }
            ],
            "regex": "^Arachni"
          }
        }
      ],
      "on_match": ["block"]
    }
  ]
}
